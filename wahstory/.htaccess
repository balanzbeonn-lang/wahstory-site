# Enable Rewrite Engine
RewriteEngine on

# Force SSL
RewriteCond %{SERVER_PORT} ^80$
RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/[0-9a-zA-Z_-]+$
RewriteCond %{REQUEST_URI} !^/\.well-known/cpanel-dcv/[0-9a-zA-Z_-]+$
RewriteCond %{REQUEST_URI} !^/\.well-known/pki-validation/(?:\ Ballot169)?
RewriteCond %{REQUEST_URI} !^/\.well-known/pki-validation/[A-F0-9]{32}\.txt(?:\ Comodo\ DCV)?$
RewriteRule ^(.*)$ https://%{SERVER_NAME}%{REQUEST_URI} [L,R]

# Remove trailing slash (non-directories)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Rewrite clean URLs (e.g., /story/my-story -> /story.php?slug=my-story)
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# Specific Rewrite Rules
RewriteRule ^story/(.*) /single.php?slug=$1 [NC]
RewriteRule ^blog/(.*) /blog.php?slug=$1 [NC]
RewriteRule ^stories/(.*) /stories.php?slug=$1 [NC]
RewriteRule ^search/(.*) /stories.php?query=$1 [NC]

# Redirect old Wah Spotlight URL
RewriteRule ^wahspotlight/nominee/(.*)$ /story/$1 [R=301,L]

# Redirect /v2/ to /
RewriteCond %{HTTP_HOST} !^www.wahstory.com$ [NC]
RewriteRule ^(.*)$ https://www.wahstory.com/$1 [L,R=301]

# Other specific redirects
RewriteRule ^wahspotlight/cat/(.*) /wahspotlight/cat.php?cat=$1 [NC]
RewriteRule ^wahspotlight/winners/(.*) /wahspotlight/winners.php?cat=$1 [NC]
RewriteRule ^wahspotlight/finalists/(.*) /wahspotlight/finalists.php?cat=$1 [NC]

# Custom 404 error page
ErrorDocument 404 /custom-404-notFound.php

# Disable directory listing
Options -Indexes

## PHP handler (cPanel)
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>

## Enable Caching
ExpiresActive On

## Images - Cache for one year
ExpiresByType image/jpg "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"

## JavaScript - Cache for one year
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType application/x-javascript "access plus 1 year"

## CSS - Cache for one year
ExpiresByType text/css "access plus 1 year"

## Fonts - Cache for one year
ExpiresByType application/font-woff2 "access plus 1 year"
ExpiresByType application/font-woff "access plus 1 year"
ExpiresByType application/x-font-ttf "access plus 1 year"
ExpiresByType font/opentype "access plus 1 year"

## Cache-Control for improved caching
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "\.(css|js)$">
  Header set Cache-Control "public, max-age=31536000, must-revalidate"
</FilesMatch>

## Security Headers
# Prevent Clickjacking
Header always append X-Frame-Options SAMEORIGIN

# Prevent MIME Sniffing
Header always set X-Content-Type-Options "nosniff"

# Content Security Policy (CSP) - Adjust as needed
Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' https://fonts.googleapis.com;"

# Strict-Transport-Security (HSTS) - Optional (forces HTTPS)
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
